# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

POSTGRES_HOST=localhost
POSTGRES_PORT=5432

POSTGRES_ADMIN_DATABASE=postgres
POSTGRES_DATABASE=querypilot

# add your postgres user and password
POSTGRES_ADMIN_USER=
POSTGRES_ADMIN_PASSWORD=

POSTGRES_READ_ONLY_USER=querypilot_reader
POSTGRES_READ_ONLY_PASSWORD=querypilot_reader_password

POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=5
POSTGRES_CONNECT_TIMEOUT_SECONDS=10

QUERYPILOT_SEED_BASE_URL=https://raw.githubusercontent.com/QueryPilot/studio/master/seeds/postgres
QUERYPILOT_SEED_CACHE_DIR=.cache/querypilot

LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_CHAT_MODEL=qwen3.5:9b
LLM_TIMEOUT_SECONDS=120

SQL_MAX_ROWS=100
SQL_STATEMENT_TIMEOUT_MS=10000